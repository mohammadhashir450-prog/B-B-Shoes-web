# ==========================================
# DATABASE CONFIGURATION
# ==========================================
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority"

# ==========================================
# APPLICATION SETTINGS
# ==========================================
NEXT_PUBLIC_APP_NAME="B&B Shoes"
NEXT_PUBLIC_APP_URL="https://your-vercel-domain.vercel.app"
NEXT_PUBLIC_API_URL="https://your-vercel-domain.vercel.app/api"
NODE_ENV="production"
DEBUG="false"

# ==========================================
# AUTHENTICATION & SECURITY
# ==========================================
ADMIN_PASSWORD="<admin-password>"
JWT_SECRET="<long-random-jwt-secret>"
NEXTAUTH_SECRET="<long-random-nextauth-secret>"
NEXTAUTH_URL="https://your-vercel-domain.vercel.app"
SESSION_SECRET="<long-random-session-secret>"

# Google OAuth
GOOGLE_CLIENT_ID="<google-client-id>.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="<google-client-secret>"

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
EMAIL_USER="your-email@gmail.com"
EMAIL_APP_PASSWORD="your-app-password"
EMAIL_FROM="B&B Shoes <support@example.com>"

# ==========================================
# BUSINESS & POLICY SETTINGS
# ==========================================
STORE_NAME="B&B Shoes"
STORE_TAGLINE="BRANDS YOU LIKE!"
SHIPPING_FEE="200"
CURRENCY="PKR"
CONTACT_PHONE="03361673742"
CONTACT_EMAIL="b&bshoessupport@gmail.com"
EXCHANGE_POLICY_DAYS="7"
RETURN_ALLOWED="false"
EXCHANGE_ALLOWED="true"

# ==========================================
# BRAND COLORS
# ==========================================
NEXT_PUBLIC_PRIMARY_COLOR="#0047AB"
NEXT_PUBLIC_SECONDARY_COLOR="#FFC107"

# ==========================================
# THIRD-PARTY SERVICES
# ==========================================
STRIPE_PUBLIC_KEY="pk_test_placeholder"
STRIPE_SECRET_KEY="sk_test_placeholder"
JAZZCASH_MERCHANT_ID="placeholder"
JAZZCASH_PASSWORD="placeholder"
EASYPAISA_STORE_ID="placeholder"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
TWILIO_ACCOUNT_SID="your-account-sid"
TWILIO_AUTH_TOKEN="your-auth-token"
